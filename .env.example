# Copy this file to ".env" and fill in real values. Never commit the real .env file.

# --- Postgres (used by docker-compose to create the db service) ---
POSTGRES_USER=witness
POSTGRES_PASSWORD=your_password
POSTGRES_DB=witness_db

# --- Backend (FastAPI) ---
# Must match the postgres credentials above. "db" is the service name in docker-compose.
DATABASE_URL=postgresql://witness:witness_password@db:5432/witness_db

SECRET_KEY=your-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

ENVIRONMENT=development

# Redis + Celery
REDIS_URL=redis://redis:6379/0

# --- AI (used from Phase 5 onward) ---
OPENROUTER_API_KEY=your-openrouter-key
OPENROUTER_MODEL=anthropic/claude-3-haiku
